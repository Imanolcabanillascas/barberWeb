---
const pilares = [
  { titulo: "Calidad", desc: "Productos y técnicas de primer nivel." },
  { titulo: "Estilo", desc: "Cortes adaptados a tu personalidad." },
  { titulo: "Puntualidad", desc: "Respetamos tu tiempo siempre." },
];
---
<section id="nosotros" class="py-24 border-t border-white/10">
  <div class="max-w-4xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
    {pilares.map(p => (
      <div>
        <div class="h-px w-8 bg-white/30 mx-auto mb-6"></div>
        <h3 class="font-['Cormorant_Garamond'] text-3xl mb-3 font-light">{p.titulo}</h3>
        <p class="text-white/40 text-sm leading-relaxed">{p.desc}</p>
      </div>
    ))}
  </div>
</section>